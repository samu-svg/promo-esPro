# =============================================================================
# PromoçãoPro — variáveis de ambiente do scraper
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA comite o `.env` no Git.
# =============================================================================

# --- Mercado Livre (Developer App) ---
MELI_CLIENT_ID=3984013574335390
MELI_CLIENT_SECRET=
MELI_AFFILIATE_ID=andeciofmendes
MELI_SITE_ID=MLB

# --- Filtros de curadoria ---
MIN_DISCOUNT_PERCENT=30
MIN_RATING=4.0
MAX_ITEMS_PER_CATEGORY=50

# --- Loop ---
SCRAPER_INTERVAL_MINUTES=30

# --- Limpeza ---
# Apaga promoções que não aparecem na fonte há N horas (padrão: 168h = 7 dias).
STALE_PROMO_HOURS=168

# --- Sincronização rápida ---
# true = título/descrição do ML (sem curadoria completa). false = curadoria GPT/Claude.
FAST_SYNC=true

# --- Classificação por IA ---
# true = novos itens têm categoria definida pela IA (prompt leve). false = só mapa ML.
AI_CLASSIFY=true

# --- Supabase (preenchido na Etapa 3) ---
SUPABASE_URL=https://xtgnqttklwsyecrutmut.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Curadoria IA (Etapa 3) ---
# Provider ativo: openai (padrão, GPT-4o mini) | anthropic (Claude Haiku)
CURATOR_PROVIDER=openai

# OpenAI — pipeline diário / reclassificação em massa
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — mantido para tarefas pontuais (--provider anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
